{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User Profile",
  "description": "Schema for user profile data",
  "type": "object",
  "required": ["id", "username", "email"],
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique user identifier",
      "minimum": 1
    },
    "username": {
      "type": "string",
      "description": "User login name",
      "minLength": 3,
      "maxLength": 50,
      "pattern": "^[a-zA-Z0-9_]+$"
    },
    "email": {
      "type": "string",
      "description": "User email address",
      "format": "email"
    },
    "profile": {
      "type": "object",
      "description": "User profile information",
      "properties": {
        "firstName": {
          "type": "string",
          "maxLength": 100
        },
        "lastName": {
          "type": "string",
          "maxLength": 100
        },
        "age": {
          "type": "integer",
          "minimum": 0,
          "maximum": 150
        },
        "bio": {
          "type": "string",
          "maxLength": 500
        },
        "avatar": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "roles": {
      "type": "array",
      "description": "User roles",
      "items": {
        "type": "string",
        "enum": ["admin", "user", "moderator", "guest"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "settings": {
      "type": "object",
      "properties": {
        "notifications": {
          "type": "boolean"
        },
        "theme": {
          "type": "string",
          "enum": ["light", "dark", "auto"]
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}-[A-Z]{2}$"
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": ["object", "null"]
    }
  },
  "additionalProperties": false
}
